{
  "site": {
    "title": "Mainline",
    "base_url": "https://mainline-astro-template.vercel.app",
    "base_path": "/",
    "trailing_slash": true,
    "favicon": "/favicon/favicon.svg",
    "logo": "/logo.svg",
    "logo_width": "94",
    "logo_height": "18",
    "logo_text": "Mainline"
  },
  "settings": {
    "pagination": 3,
    "summary_length": 120,
    "blog_folder": "blog"
  },
  "params": {
    "contact_form_action": "/api/contact",
    "footer_description": "Mainline is the fit-for-purpose tool for planning and building modern software products.",
    "copyright": "Copyright © {year} Mainline. All Rights Reserved"
  },
  "google_tag_manager": {
    "enable": false,
    "gtm_id": "GTM-XXXXXX"
  },
  "navigation_buttons": {
    "dashboard": {
      "label": "Get template",
      "link": "https://github.com/shadcnblocks/mainline-astro-template"
    },
    "login": {
      "label": "Login",
      "link": "/login"
    }
  },
  "metadata": {
    "meta_author": "shadcnblocks.com",
    "meta_image": "/og-image.jpg",
    "meta_description": "Mainline is an open-source website template built with shadcn/ui, Tailwind 4 & Astro 5"
  }
}
