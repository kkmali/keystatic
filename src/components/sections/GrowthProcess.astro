---
import { Icon } from '@/components/Icon';

interface StepItem {
  logo: string;
  title: string;
  content: string;
}

interface ButtonConfig {
  enable: boolean;
  label: string;
  link: string;
}

interface Props {
  title: string;
  content: string;
  items: StepItem[];
  button?: ButtonConfig;
}

const { title, content, items, button } = Astro.props;
---

<section class="py-24 lg:py-32 bg-muted/30 border-b border-border relative overflow-hidden">
  {/* Soft background glow */}
  <div class="pointer-events-none absolute left-1/2 top-1/2 -translate-x-1/2 -translate-y-1/2 h-[500px] w-[500px] rounded-full bg-primary/5 blur-3xl"></div>

  <div class="container mx-auto px-4 relative z-10">
    
    {/* Section Header */}
    <div class="mx-auto max-w-3xl text-center mb-16 md:mb-24">
      <h2 class="font-display text-3xl font-bold tracking-tight text-foreground sm:text-4xl">
        <Fragment set:html={title} />
      </h2>
      <p class="mt-4 text-lg text-muted-foreground leading-relaxed">
        {content}
      </p>
    </div>

    {/* Steps Flow Grid */}
    <div class="relative mx-auto max-w-5xl">
      {/* Connector line for large screens */}
      <div class="absolute top-1/2 left-[10%] right-[10%] h-0.5 -translate-y-1/2 bg-border hidden lg:block z-0"></div>

      <div class="grid gap-12 lg:grid-cols-3 relative z-10">
        {items && items.map((item, index) => (
          <div class="flex flex-col items-center text-center group">
            {/* Step Icon Circle */}
            <div class="flex h-16 w-16 items-center justify-center rounded-2xl bg-card border border-border/80 shadow-md transition-all duration-300 group-hover:border-primary/50 group-hover:bg-primary/5 group-hover:scale-110">
              <Icon name={item.logo} client:only="react" className="size-8 text-primary transition-transform duration-300 group-hover:rotate-6" />
            </div>

            {/* Step Number Badge */}
            <span class="mt-6 inline-flex items-center rounded-full bg-primary/10 px-3 py-1 text-xs font-semibold text-primary">
              Step {index + 1}
            </span>

            {/* Step Title & Content */}
            <h3 class="font-display mt-4 text-xl font-bold text-foreground transition-colors group-hover:text-primary">
              {item.title}
            </h3>
            <p class="mt-3 text-sm text-muted-foreground leading-relaxed max-w-xs">
              {item.content}
            </p>
          </div>
        ))}
      </div>
    </div>

    {/* Bottom Button Action */}
    {button && button.enable && (
      <div class="mt-16 flex justify-center">
        <a
          href={button.link}
          class="inline-flex items-center justify-center rounded-lg bg-primary px-6 py-3 text-base font-semibold text-primary-foreground shadow-md transition-all hover:bg-primary/95 hover:scale-[1.02]"
        >
          {button.label}
        </a>
      </div>
    )}

  </div>
</section>
