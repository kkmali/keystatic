---
import { Icon } from '@/components/Icon';

interface NeedItem {
  title: string;
  number: string;
  icon: string;
  content: string;
}

interface Props {
  title: string;
  content: string;
  items: NeedItem[];
}

const { title, content, items } = Astro.props;
---

<section class="py-24 lg:py-32 bg-muted/20 border-b border-border relative overflow-hidden">
  <div class="pointer-events-none absolute left-0 bottom-0 h-96 w-96 rounded-full bg-primary/5 blur-3xl"></div>

  <div class="container mx-auto px-4 relative z-10">
    
    {/* Section Header */}
    <div class="mx-auto max-w-3xl text-center mb-16 md:mb-24">
      <h2 class="font-display text-3xl font-bold tracking-tight text-foreground sm:text-4xl">
        <Fragment set:html={title} />
      </h2>
      <p class="mt-4 text-lg text-muted-foreground leading-relaxed">
        {content}
      </p>
    </div>

    {/* Items Grid */}
    <div class="grid gap-8 sm:grid-cols-1 md:grid-cols-2 lg:grid-cols-3 max-w-6xl mx-auto">
      {items && items.map((item) => (
        <div class="group relative overflow-hidden rounded-2xl border border-border/80 bg-card p-8 shadow-xs transition-all duration-300 hover:border-primary/40 hover:shadow-md hover:scale-[1.01]">
          {/* Big Background Number */}
          <div class="absolute right-4 top-4 select-none text-5xl font-bold tracking-tighter text-muted/20 font-display transition-colors group-hover:text-primary/10">
            {item.number}
          </div>

          <div class="space-y-4">
            {/* Need Icon */}
            <div class="flex h-12 w-12 items-center justify-center rounded-xl bg-primary/10 text-primary transition-transform duration-300 group-hover:scale-110">
              <Icon name={item.icon} client:only="react" className="size-6" />
            </div>

            {/* Need Title */}
            <h3 class="font-display text-xl font-bold text-foreground group-hover:text-primary transition-colors">
              {item.title}
            </h3>

            {/* Need Content */}
            <p class="text-sm text-muted-foreground leading-relaxed">
              {item.content}
            </p>
          </div>
        </div>
      ))}
    </div>

  </div>
</section>
