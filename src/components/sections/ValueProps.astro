---
interface Item {
  title: string;
  description: string;
}

interface Props {
  title: string;
  content: string;
  items: Item[];
}

const { title, content, items } = Astro.props;
---

<section class="py-24 lg:py-32 bg-background border-b border-border relative">
  <div class="pointer-events-none absolute right-10 bottom-10 h-72 w-72 rounded-full bg-primary/5 blur-3xl"></div>

  <div class="container mx-auto px-4">
    <div class="grid gap-12 lg:grid-cols-3 lg:gap-16 items-start">
      
      {/* Header Info Left Side */}
      <div class="lg:col-span-1 space-y-6">
        <h2 class="font-display text-3xl font-bold tracking-tight text-foreground sm:text-4xl">
          <Fragment set:html={title} />
        </h2>
        <p class="text-lg text-muted-foreground leading-relaxed">
          {content}
        </p>
      </div>

      {/* Grid of Items Right Side */}
      <div class="lg:col-span-2 grid gap-6 sm:grid-cols-1 md:grid-cols-2">
        {items && items.map((item, index) => (
          <div class="group relative overflow-hidden rounded-xl border border-border/80 bg-card p-6 shadow-xs transition-all duration-300 hover:border-primary/40 hover:shadow-md hover:scale-[1.01]">
            <div class="absolute top-0 left-0 h-1 w-0 bg-primary transition-all duration-300 group-hover:w-full"></div>
            
            {/* Header Number or Indicator */}
            <div class="flex items-center gap-3 mb-4">
              <span class="flex h-8 w-8 items-center justify-center rounded-lg bg-primary/10 text-xs font-semibold text-primary">
                0{index + 1}
              </span>
              <h3 class="font-display font-semibold text-lg text-foreground group-hover:text-primary transition-colors">
                {item.title}
              </h3>
            </div>

            <p class="text-sm text-muted-foreground leading-relaxed">
              {item.description}
            </p>
          </div>
        ))}
      </div>

    </div>
  </div>
</section>
